// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
}

enum ReservationStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum ReservationType {
  STUDY
  MEETING
  EVENT
  CLASS
}

model User {
  id        String @id @default(cuid())
  email     String @unique
  firstName String
  lastName  String

  passwordHash String
  role         Role   @default(STUDENT)

  reservations        Reservation[]
  reservationComments ReservationComment[]

  updatedReservations Reservation[] @relation("ReservationStatusUpdater")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

	isEmailVerified Boolean @default(false)
  emailVerifications EmailVerification[]
}

model Room {
  id          String  @id @default(cuid())
  name        String
  capacity    Int
  description String?

  buildingId String
  building   Building @relation(fields: [buildingId], references: [id])

  reservations Reservation[]

  @@unique([buildingId, name])
}

model Reservation {
  id String @id @default(cuid())

  userId String
  roomId String

  startTime             DateTime
  endTime               DateTime
  type                  ReservationType
  anticipatedAttendance Int
  purpose               String
  suppliesNeeded        String?
  contactName           String
  contactEmail          String
  contactPhone          String

  status            ReservationStatus @default(PENDING)
  statusUpdatedAt   DateTime?
  statusUpdatedById String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  statusUpdatedBy User? @relation("ReservationStatusUpdater", fields: [statusUpdatedById], references: [id])

  comments ReservationComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId, startTime, endTime])
}

model Building {
  id   String @id @default(cuid())
  name String @unique

  mapTop  Float
  mapLeft Float

  rooms Room[]
}

model ReservationComment {
  id String @id @default(cuid())

  reservationId String
  userId        String
  parentId      String?

  content String

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  parent  ReservationComment?  @relation("ReservationCommentReplies", fields: [parentId], references: [id])
  replies ReservationComment[] @relation("ReservationCommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}